# Godot cache
.godot/
*.import

# Generated scene output (produced by sceneplan_to_tscn.py — not committed)
scenes/generated/

# Android build artefacts
export/
android/
*.apk
*.aab

# Editor metadata
.mono/

# F9 room-preview screenshots (tools/screenshot_room.gd output + A/B copies)
tools/_*.png

# F9 raw source assets (asset_src/) — large, reproducible by re-downloading from the
# source (provenance in assets/models/*/CREDITS.md). Only the conditioned .glb +
# manifest under assets/models/ are committed (the shippable artefacts the converter
# references). *.import regenerates on import like the generated scenes do.
asset_src/
