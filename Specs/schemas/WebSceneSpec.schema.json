{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://hypermage.vr/schemas/WebSceneSpec.schema.json",
    "title": "Web Scene Spec",
    "description": "Babylon.js scene specification derived from a ScenePlan. Generated by WebPlatformAgent. Consumed by the web renderer to build the browser experience.",
    "type": "object",
    "required": [
        "scene_plan_id",
        "scene_name",
        "babylon_version",
        "camera",
        "lighting",
        "meshes",
        "audio"
    ],
    "properties": {
        "scene_plan_id": {
            "type": "string",
            "format": "uuid",
            "description": "The ScenePlan this was generated from"
        },
        "scene_name": {
            "type": "string",
            "description": "Human-readable scene name"
        },
        "babylon_version": {
            "type": "string",
            "description": "Target Babylon.js version. E.g. '7.x'"
        },
        "camera": {
            "type": "object",
            "required": ["type", "initial_position"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["arc_rotate", "universal", "follow", "free"],
                    "description": "Babylon.js camera type"
                },
                "initial_position": {
                    "type": "object",
                    "required": ["x", "y", "z"],
                    "properties": {
                        "x": {"type": "number"},
                        "y": {"type": "number"},
                        "z": {"type": "number"}
                    }
                },
                "target": {
                    "type": "object",
                    "properties": {
                        "x": {"type": "number"},
                        "y": {"type": "number"},
                        "z": {"type": "number"}
                    }
                }
            }
        },
        "lighting": {
            "type": "object",
            "required": ["ambient_color", "lights"],
            "properties": {
                "ambient_color": {
                    "type": "string",
                    "description": "Hex colour for ambient light. E.g. '#1a0a2e'"
                },
                "clear_color": {
                    "type": "string",
                    "description": "Background/sky colour. E.g. '#000011'"
                },
                "lights": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["type", "color", "intensity"],
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": ["hemispheric", "directional", "point", "spot"]
                            },
                            "color": {"type": "string"},
                            "intensity": {"type": "number", "minimum": 0, "maximum": 2},
                            "position": {
                                "type": "object",
                                "properties": {
                                    "x": {"type": "number"},
                                    "y": {"type": "number"},
                                    "z": {"type": "number"}
                                }
                            }
                        }
                    }
                }
            }
        },
        "meshes": {
            "type": "array",
            "description": "Scene objects — either generated primitives or references to glTF assets from the catalogue",
            "items": {
                "type": "object",
                "required": ["id", "source"],
                "properties": {
                    "id": {"type": "string"},
                    "source": {
                        "type": "string",
                        "enum": ["primitive", "gltf_catalogue", "gltf_url"],
                        "description": "'primitive' = Babylon.js built-in shape. 'gltf_catalogue' = asset from S3 catalogue. 'gltf_url' = direct URL."
                    },
                    "primitive_type": {
                        "type": "string",
                        "enum": ["box", "sphere", "cylinder", "plane", "ground", "torus"],
                        "description": "Required if source is 'primitive'"
                    },
                    "asset_id": {
                        "type": "string",
                        "description": "Asset catalogue ID (required if source is 'gltf_catalogue')"
                    },
                    "url": {
                        "type": "string",
                        "description": "Direct glTF URL (required if source is 'gltf_url')"
                    },
                    "position": {
                        "type": "object",
                        "properties": {
                            "x": {"type": "number"},
                            "y": {"type": "number"},
                            "z": {"type": "number"}
                        }
                    },
                    "rotation": {
                        "type": "object",
                        "description": "Rotation in radians (Babylon.js convention)",
                        "properties": {
                            "x": {"type": "number"},
                            "y": {"type": "number"},
                            "z": {"type": "number"}
                        }
                    },
                    "scale": {
                        "type": "object",
                        "properties": {
                            "x": {"type": "number"},
                            "y": {"type": "number"},
                            "z": {"type": "number"}
                        }
                    },
                    "material": {
                        "type": "object",
                        "description": "Optional Babylon.js material override",
                        "properties": {
                            "diffuse_color": {"type": "string"},
                            "emissive_color": {"type": "string"},
                            "specular_color": {"type": "string"},
                            "alpha": {"type": "number", "minimum": 0, "maximum": 1}
                        }
                    },
                    "narrative_state_visibility": {
                        "type": "array",
                        "description": "If set, mesh is only visible in these narrative states",
                        "items": {"type": "string"}
                    }
                }
            }
        },
        "audio": {
            "type": "object",
            "description": "Audio configuration for the web scene",
            "properties": {
                "ambient_track": {
                    "type": "string",
                    "description": "S3 URI or CDN URL of the ambient audio OGG to loop"
                },
                "music_track": {
                    "type": "string",
                    "description": "S3 URI or CDN URL of the background music OGG"
                },
                "spatial_sounds": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["url", "position"],
                        "properties": {
                            "url": {"type": "string"},
                            "position": {
                                "type": "object",
                                "properties": {
                                    "x": {"type": "number"},
                                    "y": {"type": "number"},
                                    "z": {"type": "number"}
                                }
                            },
                            "max_distance": {"type": "number"},
                            "loop": {"type": "boolean", "default": true}
                        }
                    }
                }
            }
        },
        "post_process": {
            "type": "object",
            "description": "Babylon.js post-processing pipeline",
            "properties": {
                "bloom": {"type": "boolean", "default": false},
                "chromatic_aberration": {"type": "boolean", "default": false},
                "grain": {"type": "boolean", "default": false},
                "vignette": {"type": "boolean", "default": false}
            }
        },
        "websocket_endpoint": {
            "type": "string",
            "description": "WebSocket server URL for multiplayer presence and narrative state sync"
        },
        "deployment": {
            "type": "object",
            "description": "Deployment metadata set by WebPlatformAgent after deployment",
            "properties": {
                "cloudfront_url": {"type": "string"},
                "s3_key": {"type": "string"},
                "deployed_at": {"type": "string", "format": "date-time"}
            }
        }
    }
}
